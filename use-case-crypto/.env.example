# =============================================================================
# SECRETS - Per-developer, DO NOT COMMIT
# =============================================================================
# Copy this file to `.env`, populate the values you have, and run
#
#   ../platform/scripts/seed-vault-from-env.sh use-case-crypto/.env
#
# from the repo root. That creates a K8s Secret `vault-bootstrap-seed` in
# namespace `security`; the next `kubectl apply -k platform/components/security/vault`
# seeds these values into Vault on first run. After that, Vault is the
# source of truth - rotate credentials with `vault kv put`, not by editing
# this file. ExternalSecrets (manifests/base/external-secrets.yaml) pull
# them back into the cluster.
#
# Missing keys are randomised or left as the placeholder `REPLACE_ME` for
# API keys that cannot be auto-generated. A service that needs a real API
# key will crash-loop visibly rather than silently authenticate with an
# empty token.
# =============================================================================

# --- Crypto data source API keys (populate these, the rest is optional) ---
COINBASE_API_KEY=your-coinbase-api-key
COINBASE_API_SECRET=your-coinbase-api-secret
COINGECKO_API_KEY=your-coingecko-api-key

# --- Sentiment feed API keys ---
CRYPTOPANIC_API_KEY=your-cryptopanic-api-key
NEWSAPI_KEY=your-newsapi-key

# --- Use-case pipeline secrets (leave blank -> auto-generated) ---
# CRYPTO_JWT_SECRET=
# CRYPTO_MLFLOW_TRACKING_PASSWORD=

# --- Dashboard demo-user passwords (leave blank -> auto-generated) ---
# CRYPTO_DASHBOARD_DATAENG_PASS=
# CRYPTO_DASHBOARD_DATASCI_PASS=
# CRYPTO_DASHBOARD_MLENG_PASS=
# CRYPTO_DASHBOARD_BUSUSER_PASS=

# --- Platform infrastructure secrets (leave blank -> auto-generated) ---
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=
# MINIO_KMS_KEY=
# GRAFANA_ADMIN_PASSWORD=
# GRAFANA_OIDC_CLIENT_SECRET=
# SPICEDB_PRESHARED_KEY=
# SPICEDB_POSTGRES_PASSWORD=
# POSTGRES_SUPERUSER_PASSWORD=
# FEAST_POSTGRES_PASSWORD=
# CLICKHOUSE_ADMIN_PASSWORD=
# KAFKA_ADMIN_PASSWORD=
# APISIX_ADMIN_KEY=
# DATAHUB_ADMIN_SECRET=
# LAKEKEEPER_ENCRYPTION_KEY=
