# KEDA ScaledObject template — lag-driven autoscaling for Strimzi KafkaConnect.
#
# Why this template exists:
#   Strimzi reconciles KafkaConnect via a StrimziPodSet, not a vanilla apps/v1
#   Deployment, so a stock HPA with scaleTargetRef={apps/v1, Deployment} resolves
#   FailedGetScale. KEDA can target the KafkaConnect /scale subresource that
#   Strimzi exposes since v0.41 (kafka.strimzi.io/v1beta2 KafkaConnect kind).
#
# Domain-agnostic by construction:
#   - All ${VAR} placeholders are parameterized by the use-case overlay
#     (e.g. use-case-crypto/overlays/prod/keda/kafka-connect-scaledobject.yaml).
#   - platform/ stays free of business-topic identifiers (orderbook, ticker,
#     trades, candles, etc.). Pin those in use-case-* overlays only.
#
# Apply path:
#   1. Copy this file into a use-case overlay and rename .yaml.tmpl -> .yaml.
#   2. Substitute every ${VAR} placeholder (envsubst, kustomize replacement,
#      or hand-edit). Required: USE_CASE_NAMESPACE, KAFKA_CONNECT_NAME,
#      KAFKA_BOOTSTRAP, CONSUMER_GROUP, TRIGGER_TOPIC, LAG_THRESHOLD,
#      MIN_REPLICAS, MAX_REPLICAS.
#   3. Reference from the overlay's kustomization.yaml resources list.
#
# Strimzi prerequisite:
#   spec.replicas is owned by the /scale subresource. Set Strimzi
#   strimzi.io/pause-reconciliation=true is NOT required; Strimzi v0.41+
#   delegates replicas to whatever scales the subresource.
---
apiVersion: keda.sh/v1alpha1
kind: TriggerAuthentication
metadata:
  name: kafka-connect-trigger-auth
  namespace: ${USE_CASE_NAMESPACE}
spec:
  secretTargetRef:
    - parameter: sasl
      name: ${KAFKA_CLIENT_SECRET}
      key: sasl
    - parameter: username
      name: ${KAFKA_CLIENT_SECRET}
      key: username
    - parameter: password
      name: ${KAFKA_CLIENT_SECRET}
      key: password
    - parameter: tls
      name: ${KAFKA_CLIENT_SECRET}
      key: tls
    - parameter: ca
      name: ${KAFKA_CLIENT_SECRET}
      key: ca.crt
---
apiVersion: keda.sh/v1alpha1
kind: ScaledObject
metadata:
  name: kafka-connect-scaler
  namespace: ${USE_CASE_NAMESPACE}
  annotations:
    autoscaling.keda.sh/paused-replicas: ""
spec:
  scaleTargetRef:
    apiVersion: kafka.strimzi.io/v1
    kind: KafkaConnect
    name: ${KAFKA_CONNECT_NAME}
  pollingInterval: 30
  cooldownPeriod: 300
  idleReplicaCount: 0
  minReplicaCount: ${MIN_REPLICAS}
  maxReplicaCount: ${MAX_REPLICAS}
  fallback:
    failureThreshold: 3
    replicas: ${MIN_REPLICAS}
  advanced:
    horizontalPodAutoscalerConfig:
      behavior:
        scaleDown:
          stabilizationWindowSeconds: 300
          policies:
            - type: Percent
              value: 50
              periodSeconds: 60
        scaleUp:
          stabilizationWindowSeconds: 0
          policies:
            - type: Percent
              value: 100
              periodSeconds: 30
            - type: Pods
              value: 2
              periodSeconds: 30
            - type: Pods
              value: 4
              periodSeconds: 60
          selectPolicy: Max
  triggers:
    - type: kafka
      authenticationRef:
        name: kafka-connect-trigger-auth
      metadata:
        bootstrapServers: ${KAFKA_BOOTSTRAP}
        consumerGroup: ${CONSUMER_GROUP}
        topic: ${TRIGGER_TOPIC}
        lagThreshold: "${LAG_THRESHOLD}"
        offsetResetPolicy: latest
        allowIdleConsumers: "false"
        scaleToZeroOnInvalidOffset: "false"
        version: "1.0.0"
