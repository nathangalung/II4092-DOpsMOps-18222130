# =============================================================================
# PLATFORM SECRETS — DO NOT COMMIT (ADR-008)
# =============================================================================
# The platform now sources ALL credentials from HashiCorp Vault via the
# External Secrets Operator (see platform/components/security/vault/).
# This file is kept as a reference for operators who need to seed Vault
# themselves (instead of relying on the vault-bootstrap Job's randomly
# generated defaults).
#
# Usage (seeding Vault from this file):
#   set -a; source .env; set +a
#   kubectl -n vault create secret generic vault-bootstrap-seeds \
#     --from-env-file=.env
#   helm upgrade vault vault-chart \
#     --set-string seeds.fromSecret=vault-bootstrap-seeds
#
# The vault-bootstrap Job reads env vars prefixed `SEED_*`; values below
# map 1-to-1 to the Vault paths under secret/platform/*.  If a variable is
# NOT set, the Job generates a random 24–32 byte value instead — which is
# the safest default.  The literals here are intentionally empty: NEVER
# commit a real password in this file.  Use sops or git-crypt for the real
# .env.
# =============================================================================

# --- Database Credentials (platform/mysql/root) ---
# Note: there is intentionally NO PostgreSQL seed here.  The CNPG Cluster
# defaults `enableSuperuserAccess: false`, so the `postgres` role has no
# usable password.  The DB owner `platform` is generated by CNPG and
# mirrored to Vault at `secret/platform/postgres/app` by the
# vault-bootstrap Job — rotating it happens through CNPG, not this seed
# file.
SEED_MYSQL_ROOT_PASSWORD=

# --- Object Storage (platform/minio/root, platform/minio/kms) ---
SEED_MINIO_ROOT_USER=
SEED_MINIO_ROOT_PASSWORD=
SEED_MINIO_KMS_KEY=

# --- Service admin accounts (platform/<svc>/admin) ---
SEED_GRAFANA_ADMIN_PASSWORD=
SEED_SUPERSET_ADMIN_PASSWORD=
SEED_SUPERSET_SECRET_KEY=
SEED_AIRFLOW_ADMIN_PASSWORD=
SEED_MLFLOW_TRACKING_PASSWORD=
SEED_DEX_ADMIN_PASSWORD=

# --- Valkey (platform/valkey/auth) — enforced via `--requirepass`; same
#     password is distributed to every client through pipeline-secrets
#     and feast-valkey-secret. Wire protocol is RESP (Valkey 9 BSD-3-Clause
#     drop-in for Redis 8 AGPL). Leave blank to have the bootstrap Job
#     generate a random 24-byte value.
SEED_VALKEY_PASSWORD=

# --- Qdrant (platform/qdrant/admin) — admin-scope API key. Leave blank
#     for a random 32-byte value. Health endpoints (/livez /readyz /healthz)
#     are whitelisted from auth; all other requests must carry `api-key`.
SEED_QDRANT_API_KEY=
